# Story Weaver AI - Environment Configuration Example

# OpenAI API Key (Required for full AI generation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: Specific key name used in some Replit templates
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-key-here

# Server Configuration
PORT=3000

# Optional: Custom API Base URL (if using a proxy)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
